<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_scrim">

    <!-- Centered card -->
    <LinearLayout
        android:id="@+id/overlay_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="@dimen/overlay_card_margin"
        android:orientation="vertical"
        android:background="@drawable/bg_overlay_popup"
        android:padding="@dimen/overlay_card_padding"
        android:elevation="8dp">

        <!-- Title — always visible -->
        <TextView
            android:id="@+id/overlay_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/pijon_text_primary"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Message — always visible -->
        <TextView
            android:id="@+id/overlay_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_subtitle"
            android:textColor="@color/pijon_text_primary"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- ── COUNTDOWN SECTION ── shown first, hidden after countdown ends -->
        <LinearLayout
            android:id="@+id/countdown_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_lg">

            <TextView
                android:id="@+id/countdown_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="72sp"
                android:textStyle="bold"
                android:textColor="@color/pijon_primary"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/countdown_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/overlay_countdown_hint"
                android:textSize="@dimen/text_size_caption"
                android:textColor="@color/pijon_text_secondary"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_xs" />

        </LinearLayout>

        <!-- ── QUESTIONS SECTION ── fades in after countdown -->
        <LinearLayout
            android:id="@+id/questions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:alpha="0">

            <!-- Q1 label -->
            <TextView
                android:id="@+id/question1_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                android:textColor="@color/pijon_text_primary"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Q1 buttons -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_q1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="false"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_q1_positive"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_btn_q1_positive"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_q1_neutral"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_btn_q1_neutral"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_q1_negative"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_btn_q1_negative"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_stroke"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Q2 label -->
            <TextView
                android:id="@+id/question2_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/overlay_question2"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                android:textColor="@color/pijon_text_primary"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Q2 buttons -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_q2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="false"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_q2_positive"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_btn_q2_positive"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_q2_neutral"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_btn_q2_neutral"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_q2_negative"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_btn_q2_negative"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Done button — disabled until both questions answered -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/overlay_btn_done"
                android:textAllCaps="false"
                android:enabled="false"
                android:alpha="0.4" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.StatsFragment">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_sm"
        android:text="@string/stats_title"
        android:textColor="?attr/colorPrimary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Period filter chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/period_chip_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_sm"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_today"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_period_today" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_week"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_period_week" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/stats_period_all" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Summary card — shown only when there is data -->
    <LinearLayout
        android:id="@+id/stats_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:padding="@dimen/spacing_md"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:elevation="2dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Time"
                android:textSize="@dimen/text_size_caption"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/stats_total_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                tools:text="2h 15m" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/pijon_surface_variant"
            android:layout_marginHorizontal="@dimen/spacing_md" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check-ins"
                android:textSize="@dimen/text_size_caption"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/stats_total_sessions_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                tools:text="42" />

        </LinearLayout>

    </LinearLayout>

    <!-- Container: switches between empty state and list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Stats list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/stats_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm"
            tools:listitem="@layout/item_app_stat" />

        <!-- Empty state (shown when no logs exist for the selected period) -->
        <TextView
            android:id="@+id/stats_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="@dimen/spacing_xl"
            android:text="@string/stats_empty"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_size_body"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>


</LinearLayout>

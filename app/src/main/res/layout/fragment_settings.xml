<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Timer Duration Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_timer_label"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/timer_value_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <SeekBar
                android:id="@+id/timer_seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="0"
                android:max="10"
                android:progress="6" />

        </LinearLayout>

        <!-- Toggles Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md"
            android:elevation="2dp">

            <!-- Sound toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_sound_label"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_sound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Vibration toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_vibration_label"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_vibration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

        <!-- About Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_label"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_version"
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Export Data Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_export_label"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_export_desc"
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_data"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_export_btn"
                android:textAllCaps="false" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/pijon_surface_variant"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_clear_label"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_clear_desc"
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_history"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_clear_btn"
                android:textAllCaps="false"
                android:textColor="@color/pijon_negative"
                app:strokeColor="@color/pijon_negative"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
